#!/usr/bin/env zsh

clear -x
zmodload zsh/datetime

krn=${"$(</proc/sys/kernel/osrelease)"%%[-_]*}
shl=${SHELL##*/}
read t _ </proc/uptime; t=${t%.*}
upt=$(printf "%d:%02d" $((t/3600)) $((t%3600/60)))
rand() { head -c 6 <(tr -dc 'a-fA-F0-9' </dev/urandom); }

total=0
for f in $HOME/.config/zsh/{alias.zsh,env.zsh,keybind.zsh,functions/*.zsh}; do
  t=$EPOCHREALTIME
  source $f 2>/dev/null
  total=$(( total + EPOCHREALTIME - t ))
done
init=$(printf "%.0f" $(( total * 1000 )))

echo ""
echo "- offsets -  $(uname -i)  $init%"
echo "[0x$(rand)]>  krn  ;  $krn"
echo "[0x$(rand)]>  shl  ;  $shl"
echo "[0x$(rand)]>  upt  ;  $upt"
